# RNA-Seq DGE Pipeline — configuration template
# Copy this file to config.yaml and fill in the values below before running.
# The run_pipeline.sh script generates config.yaml automatically when you supply
# the arguments on the command line, so manual editing is only needed for
# advanced use cases.

# NCBI BioProject ID whose SRA runs will be downloaded and processed.
project: PRJNA316873

# GEO Series accession used to fetch sample metadata (phenoData) via GEOquery.
# Must correspond to the same study as 'project'.
gse_accession: GSE80336

# Column in the GEO phenoData table used to derive the condition factor for DESeq2.
# For GSE80336 the relevant column is 'title', which contains strings like
# 'control-2' and 'bipolar-4' that the R script simplifies to 'control'/'bipolar'.
# For other studies, supply the exact column name that holds group labels,
# e.g. 'characteristics_ch1.1' or 'disease state:ch1'.
condition_field: title

# --- Performance / execution mode -----------------------------------------
# Aligner:
#   hisat2          — CPU alignment (default; reproduces the published case study)
#   parabricks_star — GPU alignment via NVIDIA Parabricks (rna_fq2bam). Requires
#                     a GPU SLURM allocation (--gres=gpu:1) and parabricks module.
#                     run_pipeline.sh sets this automatically when invoked with --gpu.
aligner: hisat2

# Number of concurrent fasterq-dump processes during the SRA download phase.
# Each child uses 8 worker threads, so 4 × 8 = 32 cores. NCBI throttles per-IP
# throughput so values above ~4 yield diminishing returns.
download_parallel: 4

# BiocParallel workers for the DESeq2 dispersion fit. DESeq2 is CPU-only;
# no GPU port exists. Realistic speedup is small (<1 min on 36 samples),
# so 1 (serial) is a fine default. Worth bumping for studies with >100 samples.
deseq_workers: 1

# --- Test-mode knobs (leave at 0 for production runs) --------------------
# subsample_reads:  passed as fasterq-dump -X N, capping each FASTQ at N reads.
# max_samples:      truncates the SRR list to the first N samples.
# Both are used by tests/test_*.sh to run the full DAG at miniature scale.
subsample_reads: 0
max_samples:     0

# --- Optional: skip the NCBI reference download --------------------------
# Absolute paths to a pre-staged FASTA/GTF (or their .gz equivalents). When
# either key is non-empty the corresponding download rule is replaced by a
# symlink-or-decompress rule. Leave empty (default) to fetch GRCh38 from NCBI.
local_reference_fa:  ""
local_reference_gtf: ""
